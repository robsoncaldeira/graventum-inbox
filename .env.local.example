NEXT_PUBLIC_SUPABASE_URL=https://ckjiixentlgitwqoquzm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Provider WhatsApp: 'evolution' (nao-oficial) ou 'gupshup' (API oficial Meta) ───
WA_PROVIDER=evolution

# Gate de seguranca: enquanto WA_ALLOW_ALL != 'true', so estes numeros recebem envio.
# Nunca enviar para leads reais sem autorizacao (regra global Graventum).
WA_TEST_NUMBERS=5541985216023,56974262265
WA_ALLOW_ALL=false

# ─── Evolution API (provider legado) ───
EVOLUTION_API_URL=https://evolution.graventum.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=wa-business-41984973849

# ─── Gupshup (WhatsApp Business API oficial) ───
GUPSHUP_API_KEY=
GUPSHUP_APP_ID=447da184-8840-40bf-96d6-0702bf6f5d41
GUPSHUP_APP_NAME=
GUPSHUP_SOURCE=
# Token do callback: configurar a URL no painel Gupshup como
# https://graventum-inbox.vercel.app/api/webhook/gupshup?token=<GUPSHUP_WEBHOOK_TOKEN>
GUPSHUP_WEBHOOK_TOKEN=

# Realtime opcional no browser (se ausente, cai no polling SWR).
# Anon key do projeto Supabase (chave publica, respeita RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
